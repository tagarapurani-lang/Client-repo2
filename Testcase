import unittest
from selenium import webdriver
from selenium.webdriver.common.by import By

class LoginTest(unittest.TestCase):

    @classmethod
    def setUpClass(cls):
        cls.driver = webdriver.Chrome()
        cls.driver.maximize_window()
        cls.driver.get("http://localhost/login.html")

    def test_empty_username(self):
        self.driver.find_element(By.ID, "username").clear()
        self.driver.find_element(By.ID, "password").send_keys("password123")
        self.driver.find_element(By.TAG_NAME, "button").click()

        error = self.driver.find_element(By.ID, "error").text
        self.assertEqual(error, "Please enter username")

    def test_empty_password(self):
        self.driver.find_element(By.ID, "username").send_keys("testuser")
        self.driver.find_element(By.ID, "password").clear()
        self.driver.find_element(By.TAG_NAME, "button").click()

        error = self.driver.find_element(By.ID, "error").text
        self.assertEqual(error, "Please enter password")

    def test_invalid_password_length(self):
        self.driver.find_element(By.ID, "username").send_keys("testuser")
        self.driver.find_element(By.ID, "password").send_keys("123")
        self.driver.find_element(By.TAG_NAME, "button").click()

        error = self.driver.find_element(By.ID, "error").text
        self.assertEqual(error, "Password must be at least 6 characters")

    def test_valid_login(self):
        self.driver.find_element(By.ID, "username").send_keys("testuser")
        self.driver.find_element(By.ID, "password").send_keys("password123")
        self.driver.find_element(By.TAG_NAME, "button").click()

        self.assertIn("Login successful", self.driver.page_source)

    @classmethod
    def tearDownClass(cls):
        cls.driver.quit()

if __name__ == "__main__":
    unittest.main()
